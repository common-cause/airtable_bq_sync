# Copy this file to .env and fill in your credentials.
# Never commit .env to git.
# All credential env vars follow the {CREDENTIAL_NAME}_PASSWORD pattern.

# BigQuery (if needed) — full service account JSON, unquoted
# BIGQUERY_CREDENTIALS_PASSWORD={"type":"service_account",...}

# OpenAI (if needed)
# OPENAI_API_KEY_PASSWORD=sk-...

# Airtable (if needed)
# AIRTABLE_API_KEY_PASSWORD=pat...

# Action Network (if needed)
# ACTION_NETWORK_API_KEY_PASSWORD=...
